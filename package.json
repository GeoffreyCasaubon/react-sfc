{
  "name": "rsfc-monorepo",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --filter @rsfc/core run build && pnpm --filter @rsfc/vite-plugin --filter @rsfc/webpack-loader run build",
    "build:core": "pnpm --filter @rsfc/core run build",
    "build:vite-plugin": "pnpm --filter @rsfc/vite-plugin run build",
    "build:webpack-loader": "pnpm --filter @rsfc/webpack-loader run build",
    "dev:playground-vite": "pnpm --filter playground-vite run dev",
    "dev:playground-next": "pnpm --filter playground-next run dev",
    "test": "vitest run --workspace vitest.workspace.ts --passWithNoTests",
    "test:watch": "vitest --workspace vitest.workspace.ts --passWithNoTests",
    "test:coverage": "vitest run --workspace vitest.workspace.ts --passWithNoTests --coverage",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "less": "^4.6.4",
    "sass": "^1.99.0",
    "stylus": "^0.64.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
