{
  "name": "@rsfc/cli",
  "version": "1.0.0",
  "description": "CLI for React Single File Components — compile and inspect .rsfc files",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "rsfc": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/compile.d.ts",
      "import": "./dist/compile.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rsfc/core": "workspace:*",
    "esbuild": ">=0.21.0"
  },
  "peerDependencies": {
    "sass": ">=1.0.0",
    "less": ">=4.0.0",
    "stylus": ">=0.60.0"
  },
  "peerDependenciesMeta": {
    "sass": {
      "optional": true
    },
    "less": {
      "optional": true
    },
    "stylus": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": ">=18.0.0"
  }
}
