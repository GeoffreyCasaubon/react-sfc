}

.title {
  margin-top: 0;
  color: #78350f;
  font-size: 1.3rem;
}

.display {
  font-size: 3rem;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.05em;
  color: #1c1917;
  margin: 1rem 0;
  font-family: ui-monospace, monospace;
}

.controls {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  margin-bottom: 1rem;
}

.btnStart,
.btnStop,
.btnReset {
  border: none;
  border-radius: 6px;
  padding: 0.4em 1.2em;
  font-size: 1rem;
  cursor: pointer;
  font-weight: 600;
}

.btnStart {
  background: #16a34a;
  color: #fff;
}

.btnStart:hover {
  background: #15803d;
}

.btnStop {
  background: #dc2626;
  color: #fff;
}

.btnStop:hover {
  background: #b91c1c;
}

.btnReset {
  background: #e5e7eb;
  color: #374151;
}

.btnReset:hover {
  background: #d1d5db;
}

.hint {
  font-size: 0.8rem;
  color: #92400e;
  margin: 0;
}

.hint code {
  background: #fde68a;
  padding: 0.1em 0.35em;
  border-radius: 3px;
}
</style>
