<script setup lang="ts">
import { useState, useRef } from "react"

const [running, setRunning] = useState(false)
const [elapsed, setElapsed] = useState(0)
const timerRef = useRef<ReturnType<typeof setInterval> | null>(null)
const startRef = useRef(0)

const toggle = () => {
  if (running) {
    if (timerRef.current !== null) clearInterval(timerRef.current)
    timerRef.current = null
    setRunning(false)
  } else {
    startRef.current = Date.now() - elapsed
    timerRef.current = setInterval(() => {
      setElapsed(Date.now() - startRef.current)
    }, 30)
    setRunning(true)
  }
}

const reset = () => {
  if (timerRef.current !== null) clearInterval(timerRef.current)
  timerRef.current = null
  setRunning(false)
  setElapsed(0)
}

const mm = String(Math.floor(elapsed / 60000)).padStart(2, "0")
const ss = String(Math.floor((elapsed % 60000) / 1000)).padStart(2, "0")
const cs = String(Math.floor((elapsed % 1000) / 10)).padStart(2, "0")
const display = `${mm}:${ss}.${cs}`
</script>

<template>
<div className={styles.wrap}>
  <h2 className={styles.title}>Stopwatch</h2>
  <p className={styles.display}>{display}</p>
  <div className={styles.controls}>
    <button
      className={running ? styles.btnStop : styles.btnStart}
      onClick={toggle}
    >
      {running ? "Stop" : "Start"}
    </button>
    <button className={styles.btnReset} onClick={reset}>
      Reset
    </button>
  </div>
  <p className={styles.hint}>
    Powered by <code>useRef</code> + <code>setInterval</code> inside a{" "}
    <code>.rsfc</code> Single File Component.
  </p>
</div>
</template>

<style module>
.wrap {
  max-width: 340px;
  margin: 2rem auto;
  padding: 1.5rem 2rem;
  border: 2px solid #f59e0b;
  border-radius: 12px;
  font-family: system-ui, sans-serif;
