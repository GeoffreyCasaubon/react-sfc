{
  "name": "rsfc",
  "displayName": "RSFC - React Single File Components",
  "description": "Syntax highlighting, IntelliSense, diagnostics, and snippets for .rsfc files",
  "version": "0.1.0",
  "private": true,
  "publisher": "g-casau",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters"
  ],
  "keywords": [
    "react",
    "rsfc",
    "sfc",
    "single file component",
    "typescript",
    "jsx",
    "tsx"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/geoffreycasaubon/react-sfc"
  },
  "bugs": {
    "url": "https://github.com/geoffreycasaubon/react-sfc/issues"
  },
  "homepage": "https://github.com/geoffreycasaubon/react-sfc#readme",
  "activationEvents": [
    "onLanguage:rsfc"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "rsfc",
        "aliases": [
          "RSFC",
          "React SFC"
        ],
        "extensions": [
          ".rsfc"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "assets/file-icon.svg",
          "dark": "assets/file-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "rsfc",
        "scopeName": "source.rsfc",
        "path": "./syntaxes/rsfc.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.typescript": "typescript",
          "meta.embedded.block.typescriptreact": "typescriptreact",
          "meta.embedded.block.css": "css",
          "meta.embedded.block.scss": "scss",
          "meta.embedded.block.less": "less",
          "meta.embedded.block.markdown": "markdown"
        }
      }
    ],
    "snippets": [
      {
        "language": "rsfc",
        "path": "./snippets/rsfc.json"
      }
    ],
    "typescriptServerPlugins": [
      {
        "name": "@g-casau/rsfc-typescript-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ],
    "commands": [
      {
        "command": "rsfc.restartServer",
        "title": "Restart Language Server",
        "category": "RSFC"
      }
    ],
    "configuration": {
      "title": "RSFC",
      "properties": {
        "rsfc.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the RSFC language server."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "package": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish --no-dependencies",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@g-casau/rsfc-core": "workspace:*",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
