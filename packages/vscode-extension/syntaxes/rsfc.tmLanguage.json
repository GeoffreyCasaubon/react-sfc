{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "fileTypes": ["rsfc"],
  "name": "RSFC",
  "scopeName": "source.rsfc",
  "patterns": [
    { "include": "#block-template" },
    { "include": "#block-script-tsx" },
    { "include": "#block-script" },
    { "include": "#block-client-script" },
    { "include": "#block-style-scss" },
    { "include": "#block-style-less" },
    { "include": "#block-style-styl" },
    { "include": "#block-style" },
    { "include": "#block-docs" }
  ],
  "repository": {
    "block-template": {
      "name": "meta.block.template.rsfc",
      "begin": "(<)(template)((?:\\s+[^>]*)?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.template.rsfc" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "end": "(</)(template)(\\s*)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.template.rsfc" },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "contentName": "meta.embedded.block.typescriptreact",
      "patterns": [{ "include": "source.tsx" }]
    },

    "block-script-tsx": {
      "name": "meta.block.script.rsfc",
      "begin": "(<)(script)(\\s[^>]*?\\blang=\"tsx\"[^>]*?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.script.rsfc" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "end": "(</)(script)(\\s*)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.script.rsfc" },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "contentName": "meta.embedded.block.typescriptreact",
      "patterns": [{ "include": "source.tsx" }]
    },

    "block-script": {
      "name": "meta.block.script.rsfc",
      "begin": "(<)(script)((?:\\s+[^>]*)?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.script.rsfc" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "end": "(</)(script)(\\s*)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.script.rsfc" },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "contentName": "meta.embedded.block.typescript",
      "patterns": [{ "include": "source.ts" }]
    },

    "block-client-script": {
      "name": "meta.block.clientScript.rsfc",
      "begin": "(<)(clientScript)((?:\\s+[^>]*)?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.clientScript.rsfc" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "end": "(</)(clientScript)(\\s*)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.clientScript.rsfc" },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "contentName": "meta.embedded.block.typescript",
      "patterns": [{ "include": "source.ts" }]
    },

    "block-style-scss": {
      "name": "meta.block.style.rsfc",
      "begin": "(<)(style)(\\s[^>]*?\\blang=\"scss\"[^>]*?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.style.rsfc" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "end": "(</)(style)(\\s*)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.style.rsfc" },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "contentName": "meta.embedded.block.scss",
      "patterns": [{ "include": "source.css.scss" }]
    },

    "block-style-less": {
      "name": "meta.block.style.rsfc",
      "begin": "(<)(style)(\\s[^>]*?\\blang=\"less\"[^>]*?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.style.rsfc" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "end": "(</)(style)(\\s*)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.style.rsfc" },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "contentName": "meta.embedded.block.less",
      "patterns": [{ "include": "source.css.less" }]
    },

    "block-style-styl": {
      "name": "meta.block.style.rsfc",
      "begin": "(<)(style)(\\s[^>]*?\\blang=\"styl(?:us)?\"[^>]*?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.style.rsfc" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "end": "(</)(style)(\\s*)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.style.rsfc" },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "contentName": "meta.embedded.block.css",
      "patterns": [{ "include": "source.css" }]
    },

    "block-style": {
      "name": "meta.block.style.rsfc",
      "begin": "(<)(style)((?:\\s+[^>]*)?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.style.rsfc" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "end": "(</)(style)(\\s*)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.style.rsfc" },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "contentName": "meta.embedded.block.css",
      "patterns": [{ "include": "source.css" }]
    },

    "block-docs": {
      "name": "meta.block.docs.rsfc",
      "begin": "(<)(docs)((?:\\s+[^>]*)?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.docs.rsfc" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "end": "(</)(docs)(\\s*)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.rsfc" },
        "2": { "name": "entity.name.tag.block.docs.rsfc" },
        "4": { "name": "punctuation.definition.tag.end.rsfc" }
      },
      "contentName": "meta.embedded.block.markdown",
      "patterns": [{ "include": "text.html.markdown" }]
    },

    "tag-attributes": {
      "patterns": [
        {
          "match": "(\\blang\\b)\\s*=\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "entity.other.attribute-name.rsfc" },
            "2": { "name": "string.quoted.double.rsfc" }
          }
        },
        {
          "match": "(\\b(?:setup|scoped|module)\\b)\\s*(?:=\\s*(\"[^\"]*\"))?",
          "captures": {
            "1": { "name": "entity.other.attribute-name.rsfc keyword.other.rsfc" },
            "2": { "name": "string.quoted.double.rsfc" }
          }
        },
        {
          "match": "(\\w[-\\w]*)\\s*=\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "entity.other.attribute-name.rsfc" },
            "2": { "name": "string.quoted.double.rsfc" }
          }
        },
        {
          "match": "\\b\\w[-\\w]*\\b",
          "name": "entity.other.attribute-name.rsfc"
        }
      ]
    }
  }
}
