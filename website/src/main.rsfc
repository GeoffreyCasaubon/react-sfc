<script>
import { StrictMode } from 'react'
import { hydrateRoot } from 'react-dom/client'
import { BrowserRouter } from 'react-router-dom'
import App from './App.rsfc'
</script>

<clientScript>
hydrateRoot(
  document.getElementById('root')!,
  <StrictMode>
    <BrowserRouter basename="/react-sfc">
      <App />
    </BrowserRouter>
  </StrictMode>
)
</clientScript>
